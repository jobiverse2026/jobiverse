# JobiVerse local/deployment environment template
# Copy to .env.local and fill real values locally/inside the host dashboard.
# Never commit real secrets.

# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth email readiness marker
# Set true only after Supabase Auth SMTP is configured and tested with Brevo.
SUPABASE_AUTH_SMTP_READY=false

# Brevo transactional notification email API
# Supabase Auth signup/reset emails use SMTP configured inside Supabase Dashboard.
BREVO_API_KEY=
TRANSACTIONAL_EMAIL_FROM=JobiVerse <jobiverse@outlook.com>
EMAIL_WORKER_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RESUME_DOWNLOAD_PRICE_INR=199

# AI stays off until budget/privacy/commercial approval.
ENABLE_PAID_AI=false
OPENAI_API_KEY=
OPENAI_RESUME_MODEL=

# Optional analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
